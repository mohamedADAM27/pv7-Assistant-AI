# Frontend API URL (Vite environment variable)
# Leave empty for local development
# Set to your Render backend URL for production (e.g., https://yellow-page-backend.onrender.com)
VITE_API_URL=""

# GEMINI_API_KEY: Required for Gemini AI API calls.
# Get from: https://ai.google.dev/
# Set this in Render/Vercel dashboard - DO NOT commit your actual key
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# For development: http://localhost:3000
# For production: your Vercel frontend URL
APP_URL="http://localhost:3000"

# Node Environment
NODE_ENV="development"

# Server Port
PORT=3000
